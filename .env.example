# LLM / Embedding
LLM_API_KEY=replace-with-your-dashscope-api-key
QWEN_LLM_API_KEY=replace-with-your-dashscope-api-key
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-35b-a3b
ROUTER_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
ROUTER_MODEL=mimo-v2.5-pro
ROUTER_TIMEOUT_SECONDS=5
ROUTER_LLM_ENABLED=false
CLARIFICATION_LLM_ENABLED=false
LLM_GATEWAY_MAX_RETRIES=0
LLM_MODEL_GENERATION=
LLM_MODEL_ROUTER=
LLM_MODEL_REWRITE=
LLM_MODEL_HYDE=
LLM_MODEL_STEP_BACK=
LLM_MODEL_DECOMPOSE=
LLM_MODEL_INTERMEDIATE_SYNTHESIS=
LLM_MODEL_GROUNDING=
LLM_MODEL_MEMORY_SUMMARY=
LLM_MODEL_LIGHTWEIGHT_CHAT=mimo-v2.5
LLM_TIMEOUT_GENERATION_SECONDS=45
LLM_TIMEOUT_INTERMEDIATE_SYNTHESIS_SECONDS=30
LLM_TIMEOUT_REWRITE_SECONDS=8
LLM_TIMEOUT_HYDE_SECONDS=10
LLM_TIMEOUT_STEP_BACK_SECONDS=10
LLM_TIMEOUT_DECOMPOSE_SECONDS=10
LLM_TIMEOUT_GROUNDING_SECONDS=15
LLM_TIMEOUT_MEMORY_SUMMARY_SECONDS=15
LLM_TIMEOUT_LIGHTWEIGHT_CHAT_SECONDS=30
LLM_LIGHTWEIGHT_CHAT_MAX_TOKENS=320
GENERATION_MAX_CONTEXT_CHARS=4000
GENERATION_MAX_TOKENS=1000
INTERMEDIATE_SYNTHESIS_MAX_CONTEXT_CHARS=2000
INTERMEDIATE_SYNTHESIS_MAX_TOKENS=320
EMBEDDING_MODEL=text-embedding-v1
EMBEDDING_BATCH_SIZE=20

# App paths
DOCS_DIR=data/docs
INDEX_DIR=data/index
AUDIT_DIR=data/audit

# Vector store
# Use chroma for fast local development. Use milvus for production-like demos.
VECTOR_STORE_BACKEND=chroma
CHROMA_DIR=data/index/chroma
CHROMA_COLLECTION=wei_quiz_collection
PGVECTOR_TABLE_NAME=wei_quiz_vectors
PGVECTOR_EMBED_DIM=1536

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=wei_quiz_collection

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20

# PostgreSQL parent section store
POSTGRES_URL=postgresql+psycopg://postgres:postgres@localhost:5432/weiquiz
PARENT_STORE_ENABLED=true

# Auth / JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
ADMIN_INVITE_CODE=

# Retrieval
CHUNK_SIZE=512
CHUNK_OVERLAP=50
HIERARCHICAL_CHUNK_SIZES=2048,1024,256
TOP_K=5
AUTO_MERGING_ENABLED=true
AUTO_MERGING_THRESHOLD=0.5
AUTO_MERGING_MAX_CHARS=4000
RERANK_ENABLED=true
RERANK_MIN_CANDIDATES=6
RERANK_TIMEOUT_SECONDS=5
BM25_STATE_PATH=data/index/bm25_state.json
BM25_K1=1.5
BM25_B=0.75
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_TTL=21600

# OCR
OCR_ENGINE=paddleocr
OCR_STRATEGY=ocr_only
OCR_LANGUAGES=chi_sim,eng
OCR_TESSERACT_LANGUAGES=chi_sim+eng
OCR_INFER_TABLE_STRUCTURE=false
OCR_MAX_PAGES=3
OCR_OUTPUT_DIR=data/audit/ocr
OCR_PADDLE_LANG=ch
OCR_PADDLE_DET_MODEL=PP-OCRv5_mobile_det
OCR_PADDLE_REC_MODEL=PP-OCRv5_mobile_rec
OCR_PDF_DPI=120

# Observability / Phoenix
OBSERVABILITY_ENABLED=false
OBSERVABILITY_PROVIDER=phoenix
PHOENIX_PROJECT_NAME=weiquiz-agentic-rag
PHOENIX_ENDPOINT=http://localhost:6006/v1/traces

# Optional long-term memory / tools
MEM0_ENABLED=false
MEM0_MODE=platform
MEM0_API_KEY=
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=mcp
WEB_SEARCH_MOCK_ENABLED=false
MCP_SERVER_URL=
MCP_API_KEY=
